@{
    string formPrefix = ViewData["FormPrefix"]?.ToString() ?? "";
}

<div class="row g-4">
    <div class="col-md-6">
        <div class="encoder-panel rounded">
            <h6 class="fw-bold mb-3"><i class="fas fa-film me-2 text-primary"></i>Resolution</h6>

            <div class="mb-3">
                <label for="@(formPrefix)DownscalePolicy" class="form-label">Downscale Policy</label>
                <select class="form-select" id="@(formPrefix)DownscalePolicy" name="DownscalePolicy">
                    <option value="Never" selected>Never</option>
                    <option value="CapAtTarget">Cap at target</option>
                    <option value="Always">Always downscale</option>
                </select>
                <div class="form-text">"Cap at target" only downscales content above the target; "Always" forces every file down.</div>
            </div>

            <div class="mb-3">
                <label for="@(formPrefix)DownscaleTarget" class="form-label">Downscale Target</label>
                <select class="form-select" id="@(formPrefix)DownscaleTarget" name="DownscaleTarget">
                    <option value="4K">4K (2160p)</option>
                    <option value="1440p">1440p</option>
                    <option value="1080p" selected>1080p</option>
                    <option value="720p">720p</option>
                </select>
                <div class="form-text">Maximum output resolution for the downscale policy above.</div>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="encoder-panel rounded">
            <h6 class="fw-bold mb-3"><i class="fas fa-magic me-2 text-info"></i>Quality</h6>

            <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" id="@(formPrefix)TonemapHdrToSdr" name="TonemapHdrToSdr">
                <label class="form-check-label" for="@(formPrefix)TonemapHdrToSdr">Tonemap HDR → SDR</label>
                <div class="form-text">Convert HDR/HDR10/Dolby Vision sources to SDR during encode for broader device compatibility.</div>
            </div>

            <div class="mb-3">
                <label for="@(formPrefix)FfmpegQualityPreset" class="form-label">FFmpeg Preset</label>
                <select class="form-select" id="@(formPrefix)FfmpegQualityPreset" name="FfmpegQualityPreset">
                    <option value="veryfast">veryfast</option>
                    <option value="fast">fast</option>
                    <option value="medium" selected>medium</option>
                    <option value="slow">slow</option>
                    <option value="veryslow">veryslow</option>
                </select>
                <div class="form-text">Slower presets yield smaller files at the same quality.</div>
            </div>

            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="@(formPrefix)RemoveBlackBorders" name="RemoveBlackBorders">
                <label class="form-check-label" for="@(formPrefix)RemoveBlackBorders"><i class="fas fa-crop me-1"></i> Remove Black Borders</label>
                <div class="form-text">Detect and crop letterbox/pillarbox bars so no bitrate is wasted on pure-black pixels.</div>
            </div>
        </div>
    </div>
</div>
