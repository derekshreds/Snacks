@{
    string formPrefix = ViewData["FormPrefix"]?.ToString() ?? "";
}

<div class="row g-4">
    <div class="col-md-6">
        <div class="encoder-panel rounded">
            <h6 class="fw-bold mb-3 d-flex align-items-center">
                <i class="fas fa-cogs me-2 text-primary"></i>
                Video Settings
            </h6>

            <div class="mb-3">
                <label for="@(formPrefix)Format" class="form-label">
                    <i class="fas fa-file-video me-1"></i> Output Format
                </label>
                <select class="form-select" id="@(formPrefix)Format" name="Format">
                    <option value="mkv" selected>MKV (Matroska)</option>
                    <option value="mp4">MP4</option>
                </select>
                <div class="form-text">
                    <i class="fas fa-info-circle me-1"></i>
                    MP4 is widely compatible with most devices
                </div>
            </div>

            <div class="mb-3">
                <label for="@(formPrefix)Codec" class="form-label">
                    <i class="fas fa-microchip me-1"></i> Video Codec
                </label>
                <select class="form-select" id="@(formPrefix)Codec" name="Codec">
                    <option value="h265" selected>H.265/HEVC (Better Quality)</option>
                    <option value="h264">H.264/AVC (Faster)</option>
                    <option value="av1">AV1 (Best Compression)</option>
                </select>
                <div class="form-text">
                    <i class="fas fa-info-circle me-1"></i>
                    AV1 offers the best compression but is slower to encode
                </div>
            </div>

            <div class="mb-3">
                <label for="@(formPrefix)HardwareAcceleration" class="form-label">
                    <i class="fas fa-bolt me-1"></i> Hardware Acceleration
                </label>
                <select class="form-select" id="@(formPrefix)HardwareAcceleration" name="HardwareAcceleration">
                    <option value="auto" selected>Auto Detect</option>
                    <option value="intel">Intel Quick Sync (QSV)</option>
                    <option value="amd">AMD Video Acceleration (VAAPI)</option>
                    <option value="nvidia">NVIDIA NVENC</option>
                    <option value="none">None (Software Only)</option>
                </select>
                <div class="form-text">
                    <i class="fas fa-info-circle me-1"></i>
                    Hardware acceleration speeds up encoding
                </div>
            </div>

            <div class="mb-3">
                <label for="@(formPrefix)TargetBitrate" class="form-label">
                    <i class="fas fa-tachometer-alt me-1"></i> Target Bitrate (kbps)
                </label>
                <input type="number" class="form-control" id="@(formPrefix)TargetBitrate" name="TargetBitrate" value="3500" min="500" max="50000" step="100">
                <div class="form-text">
                    <i class="fas fa-info-circle me-1"></i>
                    Higher bitrate = better quality, larger file size
                </div>
            </div>

            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="@(formPrefix)StrictBitrate" name="StrictBitrate">
                <label class="form-check-label" for="@(formPrefix)StrictBitrate">
                    <i class="fas fa-lock me-1"></i> Strict Bitrate Control
                </label>
            </div>

            <div class="mb-3 mt-3">
                <label for="@(formPrefix)FourKBitrateMultiplier" class="form-label">
                    <i class="fas fa-expand me-1"></i> 4K Bitrate Multiplier
                </label>
                <select class="form-select" id="@(formPrefix)FourKBitrateMultiplier" name="FourKBitrateMultiplier">
                    <option value="2">2x</option>
                    <option value="3">3x</option>
                    <option value="4" selected>4x (Default)</option>
                    <option value="5">5x</option>
                    <option value="6">6x</option>
                    <option value="8">8x</option>
                </select>
                <div class="form-text">
                    <i class="fas fa-info-circle me-1"></i>
                    Multiplies target bitrate for 4K content
                </div>
            </div>

            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="@(formPrefix)Skip4K" name="Skip4K">
                <label class="form-check-label" for="@(formPrefix)Skip4K">
                    <i class="fas fa-ban me-1"></i> Skip 4K Videos
                </label>
                <div class="form-text ms-4">
                    Leave 4K content untouched
                </div>
            </div>

            <div class="mb-2">
                <label for="@(formPrefix)SkipPercentAboveTarget" class="form-label">
                    <i class="fas fa-forward me-1"></i> Skip Threshold
                </label>
                <div class="input-group input-group-sm">
                    <input type="number" class="form-control" id="@(formPrefix)SkipPercentAboveTarget" name="SkipPercentAboveTarget" min="0" max="100" value="20" oninput="this.value=Math.max(0,Math.min(100,parseInt(this.value)||0))">
                    <span class="input-group-text">% above target</span>
                </div>
                <div class="form-text">
                    Skip files already in target codec within this % above target bitrate
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="encoder-panel rounded">
            <h6 class="fw-bold mb-3 d-flex align-items-center">
                <i class="fas fa-sliders-h me-2 text-success"></i>
                Processing Options
            </h6>

            <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" id="@(formPrefix)TwoChannelAudio" name="TwoChannelAudio">
                <label class="form-check-label" for="@(formPrefix)TwoChannelAudio">
                    <i class="fas fa-volume-up me-1"></i> Convert to Stereo Audio
                </label>
                <div class="form-text ms-4">
                    Downmix multi-channel audio to 2.0 stereo
                </div>
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" id="@(formPrefix)EnglishOnlyAudio" name="EnglishOnlyAudio">
                <label class="form-check-label" for="@(formPrefix)EnglishOnlyAudio">
                    <i class="fas fa-language me-1"></i> Keep English Audio Only
                </label>
                <div class="form-text ms-4">
                    Remove non-English audio tracks
                </div>
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" id="@(formPrefix)EnglishOnlySubtitles" name="EnglishOnlySubtitles">
                <label class="form-check-label" for="@(formPrefix)EnglishOnlySubtitles">
                    <i class="fas fa-closed-captioning me-1"></i> Keep English Subtitles Only
                </label>
                <div class="form-text ms-4">
                    Remove non-English subtitle tracks
                </div>
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" id="@(formPrefix)RemoveBlackBorders" name="RemoveBlackBorders">
                <label class="form-check-label" for="@(formPrefix)RemoveBlackBorders">
                    <i class="fas fa-crop me-1"></i> Remove Black Borders
                </label>
                <div class="form-text ms-4">
                    Automatically crop black bars from video
                </div>
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" id="@(formPrefix)DeleteOriginalFile" name="DeleteOriginalFile">
                <label class="form-check-label" for="@(formPrefix)DeleteOriginalFile">
                    <i class="fas fa-exchange-alt me-1 text-danger"></i> Replace Original Files
                </label>
                <div class="form-text ms-4 text-danger">
                    <strong>Warning:</strong> Deletes original and moves encoded file to its location. This cannot be undone!
                </div>
            </div>

            <div class="mb-3">
                <label for="@(formPrefix)OutputDirectory" class="form-label">
                    <i class="fas fa-folder me-1"></i> Output Directory
                </label>
                <input type="text" class="form-control" id="@(formPrefix)OutputDirectory" name="OutputDirectory" placeholder="Leave blank to output next to originals">
                <div class="form-text">
                    <i class="fas fa-info-circle me-1"></i>
                    Where encoded files are saved. If Replace is enabled, files are moved back to the original location after encoding.
                </div>
            </div>

            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="@(formPrefix)RetryOnFail" name="RetryOnFail" checked>
                <label class="form-check-label" for="@(formPrefix)RetryOnFail">
                    <i class="fas fa-redo me-1"></i> Retry on Failure
                </label>
                <div class="form-text ms-4">
                    Automatically retry failed encodings
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mt-3">
    <div class="col-12">
        <div class="encoder-panel rounded">
            <h6 class="fw-bold mb-3 d-flex align-items-center">
                <i class="fas fa-sync me-2" style="color: var(--primary);"></i>
                Automatic Scanning
            </h6>

            <div class="form-check form-switch mb-3">
                <input class="form-check-input" type="checkbox" id="autoScanEnabled">
                <label class="form-check-label" for="autoScanEnabled">
                    Enable Auto-Scan
                </label>
                <div class="form-text ms-4">Automatically scan directories for new videos on a schedule</div>
            </div>

            <div class="mb-3">
                <label for="autoScanInterval" class="form-label">
                    <i class="fas fa-clock me-1"></i> Scan Interval (minutes)
                </label>
                <input type="number" class="form-control" id="autoScanInterval" value="60" min="1" max="1440" step="1">
            </div>

            <div class="mb-3">
                <label class="form-label"><i class="fas fa-folder-open me-1"></i> Watched Directories</label>
                <div id="autoScanDirectories" class="border rounded p-2" style="max-height: 200px; overflow-y: auto;">
                    <div class="text-muted text-center py-2"><small>No directories added</small></div>
                </div>
            </div>

            <div class="form-text mb-3">
                <i class="fas fa-info-circle me-1"></i>
                Use "Watch This Folder" in the directory browser to add folders
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-outline-info" id="triggerAutoScan"><i class="fas fa-play me-1"></i>Scan Now</button>
                <button class="btn btn-sm btn-outline-warning" id="clearScanHistory"><i class="fas fa-eraser me-1"></i>Clear History</button>
            </div>

            <div class="mt-3 text-muted small" id="autoScanStatus">Last scan: Never</div>
        </div>
    </div>
</div>
