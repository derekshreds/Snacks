@{
    string formPrefix = ViewData["FormPrefix"]?.ToString() ?? "";
}

<div class="row g-4">
    <div class="col-md-6">
        <div class="encoder-panel rounded">
            <h6 class="fw-bold mb-3"><i class="fas fa-layer-group me-2 text-primary"></i>Mux Pass</h6>

            <p class="form-text mb-3">
                A mux pass copies the video stream verbatim (no re-encode) and only applies the
                non-video work you select here. Useful for files that already meet bitrate targets
                but need audio or subtitle changes. Files that already satisfy every audio and
                subtitle setting are never remuxed — this feature never produces pointless output.
            </p>

            <div class="mb-3">
                <label for="@(formPrefix)MuxMode" class="form-label">Mux Mode</label>
                <select class="form-select" id="@(formPrefix)MuxMode" name="MuxMode">
                    <option value="Off" selected>Off</option>
                    <option value="Audio">Audio only</option>
                    <option value="Subtitles">Subtitles only</option>
                    <option value="Both">Audio + Subtitles</option>
                </select>
                <div class="form-text">
                    Selects which stream types the mux pass is allowed to touch. Streams outside
                    the selected type are always copied through untouched.
                </div>
            </div>

            <div class="mb-3">
                <label for="@(formPrefix)MuxScope" class="form-label">Apply To</label>
                <select class="form-select" id="@(formPrefix)MuxScope" name="MuxScope">
                    <option value="TargetMatchOnly" selected>Files meeting bitrate targets</option>
                    <option value="AllFiles">All files</option>
                </select>
                <div class="form-text">
                    <strong>Files meeting bitrate targets</strong> — only files that would
                    otherwise be skipped get the mux pass; files above target still get a
                    normal re-encode (with audio/subtitle work included).<br>
                    <strong>All files</strong> — files above target also get a video-copy
                    mux pass (audio/subtitle work only, no video re-encode). Files with no
                    audio/subtitle work are unaffected either way.
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="encoder-panel rounded">
            <h6 class="fw-bold mb-3"><i class="fas fa-circle-info me-2 text-info"></i>What a Mux Pass Does</h6>
            <ul class="mb-0 small">
                <li><strong>Video</strong> — always stream-copied. Crop, downscale, and tonemap
                    are disabled during a mux pass.</li>
                <li><strong>Audio</strong> — processed per the Audio tab when the selected mode
                    is <em>Audio only</em> or <em>Audio + Subtitles</em>; otherwise copied
                    through with every track preserved.</li>
                <li><strong>Subtitles</strong> — processed per the Subtitles tab (sidecar
                    extraction, OCR, language filter) when the selected mode is
                    <em>Subtitles only</em> or <em>Audio + Subtitles</em>; otherwise copied
                    through with every track preserved.</li>
            </ul>
        </div>
    </div>
</div>
