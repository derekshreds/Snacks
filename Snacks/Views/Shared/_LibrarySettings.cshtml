<div class="row g-4">
    <div class="col-md-6">
        <div class="encoder-panel rounded">
            <h6 class="fw-bold mb-3"><i class="fas fa-sync me-2 text-primary"></i>Auto-Scan</h6>

            <div class="form-check form-switch mb-3">
                <input class="form-check-input" type="checkbox" id="autoScanEnabled">
                <label class="form-check-label" for="autoScanEnabled">Enable Auto-Scan</label>
            </div>

            <div class="mb-3">
                <label for="autoScanInterval" class="form-label"><i class="fas fa-clock me-1"></i> Scan Interval (minutes)</label>
                <input type="number" class="form-control" id="autoScanInterval" value="60" min="1" max="1440" step="1">
            </div>

            <div class="mb-3">
                <label class="form-label"><i class="fas fa-folder-open me-1"></i> Watched Directories</label>
                <div id="autoScanDirectories" class="border rounded p-2" style="max-height: 200px; overflow-y: auto;">
                    <div class="text-muted text-center py-2"><small>No directories added</small></div>
                </div>
                <div class="form-text">Pick a folder to watch, or use "Watch This Folder" in the directory browser.</div>
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-outline-primary" id="addWatchedDirectory"><i class="fas fa-folder-plus me-1"></i>Add Directory</button>
                <button class="btn btn-sm btn-outline-info" id="triggerAutoScan"><i class="fas fa-play me-1"></i>Scan Now</button>
            </div>

            <div class="mt-3 text-muted small" id="autoScanStatus">Last scan: Never</div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="encoder-panel rounded">
            <h6 class="fw-bold mb-3"><i class="fas fa-filter me-2 text-warning"></i>Exclusion Rules</h6>

            <div class="mb-3">
                <label class="form-label">Filename Patterns to Exclude</label>
                <div class="chip-input" id="exclusionPatternsChips" data-field="FilenamePatterns">
                    <div class="chip-list"></div>
                    <input type="text" class="chip-new" placeholder="e.g. *REMUX*, *-BLURAY-*">
                </div>
            </div>

            <div class="mb-3">
                <label for="exclusionMinSize" class="form-label">Skip files larger than (GB)</label>
                <input type="number" class="form-control" id="exclusionMinSize" min="0" step="0.5" placeholder="Leave blank for no limit">
            </div>

            <div class="mb-3">
                <label class="form-label">Exclude Resolutions</label>
                <div class="chip-input" id="exclusionResolutionsChips" data-field="ExcludeResolutions">
                    <div class="chip-list"></div>
                    <input type="text" class="chip-new" placeholder="e.g. 2160p">
                </div>
            </div>

            <button class="btn btn-sm btn-primary" id="saveExclusionRules"><i class="fas fa-save me-1"></i>Save Rules</button>
        </div>
    </div>
</div>
