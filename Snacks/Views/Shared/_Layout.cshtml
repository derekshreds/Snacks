<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Snacks - Automated Video Library Encoder</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico">
    <link href="~/lib/bootstrap.min.css" rel="stylesheet">
    <link href="~/lib/fontawesome.min.css" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body class="d-flex flex-column">
    <nav class="navbar navbar-expand-sm navbar-dark border-bottom fixed-top">
        <div class="container">
            <a href="https://snacksvideo.com" target="_blank" class="navbar-brand d-flex align-items-center text-decoration-none">
                <img src="~/images/snacks.ico" alt="Snacks" style="height: 24px; width: 24px;" class="me-2">
                <span class="fw-bold">Snacks</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse">
                <ul class="navbar-nav ms-auto align-items-sm-center">
                    <li class="nav-item d-flex align-items-center py-2 py-sm-0">
                        <a class="btn btn-outline-secondary btn-sm me-2" href="/" data-spa-link title="Queue"><i class="fas fa-list-ul"></i><span class="d-none d-md-inline ms-1">Queue</span></a>
                        <a class="btn btn-outline-secondary btn-sm me-2" href="/dashboard" data-spa-link title="Dashboard"><i class="fas fa-chart-line"></i><span class="d-none d-md-inline ms-1">Dashboard</span></a>
                        <button class="btn btn-outline-secondary btn-sm me-2" id="pauseResumeBtn" title="Pause/Resume Queue"><i class="fas fa-pause" id="pauseResumeIcon"></i></button>
                        <button class="btn btn-outline-secondary btn-sm me-2" id="openSettingsBtn"><i class="fas fa-cog"></i></button>
                        <button class="btn btn-primary btn-sm" id="openLibraryBtn"><i class="fas fa-folder-plus me-1"></i><span class="d-none d-sm-inline">Browse Library</span><span class="d-sm-none">Library</span></button>
                    </li>
                    <li class="nav-item d-flex align-items-center py-1 py-sm-0 ms-sm-3">
                        <span class="nav-link d-flex align-items-center py-0" id="connectionStatus">
                            <i class="fas fa-circle text-warning me-1" id="connectionDot" style="font-size: 0.5rem;"></i>
                            <small id="connectionText"></small>
                        </span>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="container main-content">
        @*
            Page-specific content. The SPA shell in main.js swaps this element's
            innerHTML on navigation, leaving the navbar, modals, and SignalR
            connection alive across pages.
        *@
        <div id="page-content" data-page="@(ViewData["Page"] as string ?? "")">
            @RenderBody()
        </div>
    </main>

    <footer class="footer mt-auto py-3 border-top">
        <div class="container text-center">
            <span class="text-muted">
                <img src="~/images/snacks.ico" alt="Snacks" style="height: 18px; width: 18px;" class="me-2">
                <a href="https://snacksvideo.com" target="_blank" class="text-muted text-decoration-none"><strong>Snacks</strong></a> - v2.8.2 &copy; @DateTime.Now.Year - <a href="https://technobitch.com" target="_blank" class="text-muted text-decoration-none">Derek Morris</a>
            </span>
        </div>
    </footer>

    @await Html.PartialAsync("_AppModals")

    <script src="~/lib/bootstrap.bundle.min.js"></script>
    <script src="~/lib/signalr.min.js"></script>
    <script src="~/js/site.js"></script>
    <script type="module" src="~/js/main.js"></script>
</body>
</html>
