@{
    string formPrefix = ViewData["FormPrefix"]?.ToString() ?? "settings";
}

<div class="encoder-panel rounded">
    <h6 class="fw-bold mb-3"><i class="fas fa-clock me-2 text-primary"></i>Per-Node Transcode Schedule</h6>

    <!-- Master clock banner — surfaces timezone so a UTC-defaulted server doesn't trip up users
         configuring "evening" windows expecting their local wall clock. -->
    <div class="alert alert-secondary py-2 px-3 mb-3 d-flex align-items-center gap-3" id="@(formPrefix)SchedulingMasterTimeBanner">
        <i class="fas fa-server text-primary"></i>
        <div class="flex-fill">
            <div class="small text-muted">Schedules are evaluated against the master server's clock</div>
            <div>
                <strong id="@(formPrefix)SchedulingMasterClock">—</strong>
                <span class="text-muted ms-2" id="@(formPrefix)SchedulingMasterTz">—</span>
            </div>
        </div>
        <span id="@(formPrefix)SchedulingMasterUtcWarning" class="badge bg-warning text-dark d-none" title="Master is set to UTC — confirm this matches your wall-clock expectations">
            <i class="fas fa-triangle-exclamation me-1"></i>UTC
        </span>
    </div>

    <div class="form-text mb-3">
        Restrict when each node accepts new jobs. A node with no windows is always available.
        In-flight jobs run to completion regardless of window.
    </div>

    <div id="@(formPrefix)SchedulingNodeList"></div>
</div>

<template id="@(formPrefix)SchedulingNodeSectionTemplate">
    <details class="scheduling-node-section mb-3" data-scheduling-node>
        <summary class="d-flex align-items-center gap-2 py-2 px-2 rounded">
            <i class="fas fa-chevron-right scheduling-node-caret"></i>
            <span class="node-name fw-semibold" data-node-name></span>
            <span class="node-role-badge badge bg-secondary" data-node-role></span>
            <span class="ms-auto text-muted small" data-schedule-summary>Always available</span>
        </summary>
        <div class="scheduling-rows mt-2 ps-3" data-scheduling-rows></div>
        <div class="ps-3 mt-2">
            <button type="button" class="btn btn-sm btn-outline-primary" data-add-window>
                <i class="fas fa-plus"></i> Add window
            </button>
        </div>
    </details>
</template>

<template id="@(formPrefix)SchedulingWindowRowTemplate">
    <div class="scheduling-window-row d-flex align-items-end flex-wrap gap-2 mb-2" data-window-row>
        <div class="scheduling-day-chips" role="group" aria-label="Days of week">
            <button type="button" class="btn btn-sm btn-outline-secondary day-chip" data-day="0" title="Sunday">S</button>
            <button type="button" class="btn btn-sm btn-outline-secondary day-chip" data-day="1" title="Monday">M</button>
            <button type="button" class="btn btn-sm btn-outline-secondary day-chip" data-day="2" title="Tuesday">T</button>
            <button type="button" class="btn btn-sm btn-outline-secondary day-chip" data-day="3" title="Wednesday">W</button>
            <button type="button" class="btn btn-sm btn-outline-secondary day-chip" data-day="4" title="Thursday">T</button>
            <button type="button" class="btn btn-sm btn-outline-secondary day-chip" data-day="5" title="Friday">F</button>
            <button type="button" class="btn btn-sm btn-outline-secondary day-chip" data-day="6" title="Saturday">S</button>
        </div>
        <div>
            <label class="form-label form-label-sm mb-1">Start</label>
            <input type="time" class="form-control form-control-sm" data-field="Start" value="22:00">
        </div>
        <div>
            <label class="form-label form-label-sm mb-1">End</label>
            <input type="time" class="form-control form-control-sm" data-field="End" value="06:00">
        </div>
        <button type="button" class="btn btn-sm btn-outline-danger" data-remove title="Remove window">
            <i class="fas fa-trash"></i>
        </button>
    </div>
</template>
