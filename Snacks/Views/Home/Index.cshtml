@{
    ViewData["Title"] = "Video Transcoding Service";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Mobile Stats Strip -->
<div class="stats-strip d-md-none mb-3">
    <div class="stats-strip-item"><i class="fas fa-clock" style="color: var(--warning-color);"></i><span id="pendingCountMobile">0</span></div>
    <div class="stats-strip-item"><i class="fas fa-cog" style="color: var(--info-color);"></i><span id="processingCountMobile">0</span></div>
    <div class="stats-strip-item"><i class="fas fa-check-circle" style="color: var(--success-color);"></i><span id="completedCountMobile">0</span></div>
    <div class="stats-strip-item"><i class="fas fa-times-circle" style="color: var(--danger-color);"></i><span id="failedCountMobile">0</span></div>
</div>

<!-- Desktop Stats Cards -->
<div class="row mb-3 g-2 d-none d-md-flex">
    <div class="col-3">
        <div class="card hover-lift stats-card">
            <div class="card-body text-center">
                <div class="mb-3"><i class="fas fa-clock fa-3x" style="color: var(--warning-color);"></i></div>
                <h5 class="card-title mb-1" id="pendingCount">0</h5>
                <p class="card-text text-muted mb-0">Pending</p>
            </div>
        </div>
    </div>
    <div class="col-3">
        <div class="card hover-lift stats-card">
            <div class="card-body text-center">
                <div class="mb-3"><i class="fas fa-cog fa-spin fa-3x" style="color: var(--info-color);"></i></div>
                <h5 class="card-title mb-1" id="processingCount">0</h5>
                <p class="card-text text-muted mb-0">Processing</p>
            </div>
        </div>
    </div>
    <div class="col-3">
        <div class="card hover-lift stats-card">
            <div class="card-body text-center">
                <div class="mb-3"><i class="fas fa-check-circle fa-3x" style="color: var(--success-color);"></i></div>
                <h5 class="card-title mb-1" id="completedCount">0</h5>
                <p class="card-text text-muted mb-0">Completed</p>
            </div>
        </div>
    </div>
    <div class="col-3">
        <div class="card hover-lift stats-card">
            <div class="card-body text-center">
                <div class="mb-3"><i class="fas fa-exclamation-circle fa-3x" style="color: var(--danger-color);"></i></div>
                <h5 class="card-title mb-1" id="failedCount">0</h5>
                <p class="card-text text-muted mb-0">Failed</p>
            </div>
        </div>
    </div>
</div>


<!-- Node Mode Banner (hidden by default, shown via JS when in node mode) -->
<div class="row mb-3" id="nodeBanner" style="display: none;">
    <div class="col-12">
        <div class="alert alert-info d-flex align-items-center justify-content-between mb-0">
            <div>
                <i class="fas fa-satellite-dish me-2"></i>
                <strong>Node Mode</strong> — This instance is operating as a worker node for
                <span id="nodeBannerMaster">a master</span>.
                <span id="nodeBannerStatus" class="ms-2 text-muted">Waiting for jobs...</span>
            </div>
            <button class="btn btn-sm btn-outline-light" id="switchToStandalone">
                <i class="fas fa-unlink me-1"></i>Switch to Standalone
            </button>
        </div>
    </div>
</div>

<!-- Cluster Status Panel (hidden by default, shown when cluster enabled) -->
<div class="row mb-3" id="clusterPanel" style="display: none;">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center" style="cursor: pointer;" data-bs-toggle="collapse" data-bs-target="#clusterPanelBody">
                <h6 class="mb-0">
                    <i class="fas fa-network-wired me-2"></i>
                    Cluster
                    <span class="badge bg-secondary ms-2" id="clusterNodeCount">0 nodes</span>
                </h6>
                <i class="fas fa-chevron-down" id="clusterCollapseIcon"></i>
            </div>
            <div class="collapse show" id="clusterPanelBody">
                <div class="card-body">
                    <div class="d-flex flex-wrap gap-3" id="clusterNodesContainer">
                        <div class="text-muted"><i class="fas fa-search me-1"></i>Discovering nodes...</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Now Processing Section -->
<div class="row mb-4" id="processingSection" style="display: none;">
    <div class="col-md-12">
        <div class="card border-info">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="fas fa-cog fa-spin me-2 text-info"></i>
                    Now Processing
                </h5>
            </div>
            <div class="card-body" id="processingContainer">
            </div>
        </div>
    </div>
</div>

<!-- Work Queue Section -->
<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <div class="d-flex justify-content-between align-items-center flex-wrap">
                    <h5 class="mb-0">
                        <i class="fas fa-list-ul me-2"></i>
                        Queue
                    </h5>
                    <div id="queueFilterTabs" class="btn-group btn-group-sm mt-2 mt-md-0"></div>
                </div>
            </div>
            <div class="card-body">
                <div id="workItemsContainer" style="min-height: 100px;">
                    <div class="text-center text-muted py-5">
                        <i class="fas fa-inbox fa-4x mb-3" style="opacity: 0.3;"></i>
                        <h5>No work items yet</h5>
                        <p>Click "Browse Library" to add videos to the transcoding queue</p>
                    </div>
                </div>
                <div id="queuePagination"></div>
            </div>
        </div>
    </div>
</div>

<!-- Library Browser Modal -->
<div class="modal fade modal-fullscreen-mobile" id="libraryModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-folder-open me-2"></i>
                    Video Library Browser
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-lg-4">
                        <h6><i class="fas fa-folder me-2"></i>Directories</h6>
                        <div id="directoryList" class="border rounded p-2" style="height: 450px; overflow-y: auto;">
                            <div class="text-center">
                                <div class="spinner-border" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-8">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6><i class="fas fa-file-video me-2"></i>Video Files</h6>
                            <div>
                                <button id="selectAllFiles" class="btn btn-sm btn-outline-secondary me-2">
                                    <i class="fas fa-check-square me-1"></i> Select All
                                </button>
                                <button id="processSelectedFiles" class="btn btn-sm btn-primary" disabled>
                                    <i class="fas fa-play me-1"></i> Process Selected
                                </button>
                            </div>
                        </div>
                        <div id="fileList" class="border rounded p-2" style="height: 450px; overflow-y: auto;">
                            <div class="text-muted text-center py-4">
                                <i class="fas fa-folder-open fa-2x mb-2"></i><br>
                                Select a directory to view files
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" id="processDirectory">
                    <i class="fas fa-folder-plus me-2"></i>
                    Process Entire Directory
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Settings Modal -->
<div class="modal fade modal-fullscreen-mobile" id="settingsModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-cog me-2"></i>
                    Settings
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <ul class="nav nav-tabs mb-3" role="tablist">
                    <li class="nav-item">
                        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#encodingTab" type="button" role="tab">
                            <i class="fas fa-film me-1"></i> Encoding
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#clusterTab" type="button" role="tab">
                            <i class="fas fa-network-wired me-1"></i> Cluster
                        </button>
                    </li>
                </ul>
                <div class="tab-content">
                    <div class="tab-pane fade show active" id="encodingTab" role="tabpanel">
                        @await Html.PartialAsync("_EncoderOptions", null, new ViewDataDictionary(ViewData) { {"FormPrefix", "settings"} })
                    </div>
                    <div class="tab-pane fade" id="clusterTab" role="tabpanel">
                        @await Html.PartialAsync("_ClusterSettings")
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Stop/Cancel Modal -->
<div class="modal fade" id="stopCancelModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-question-circle me-2"></i>
                    Remove from Queue
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0">What would you like to do with this item?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-warning" id="stopCancelStop">
                    <i class="fas fa-pause me-1"></i>Stop (Encode Later)
                </button>
                <button type="button" class="btn btn-danger" id="stopCancelCancel">
                    <i class="fas fa-ban me-1"></i>Cancel (Don't Reprocess)
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Log Modal -->
<div class="modal fade modal-fullscreen-mobile" id="logModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-terminal me-2"></i>
                    Transcoding Log
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="logContent">
                    <!-- Log content will be loaded here -->
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Confirm Modal -->
<div class="modal fade" id="confirmModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="confirmModalTitle">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    Confirm
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="confirmModalBody">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmModalConfirm">Confirm</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/transcoding.js"></script>
}