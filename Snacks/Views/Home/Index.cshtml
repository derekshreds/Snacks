@{
    ViewData["Title"] = "Video Transcoding Service";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Mobile Stats Strip -->
<div class="stats-strip d-md-none mb-3">
    <div class="stats-strip-item"><i class="fas fa-clock" style="color: var(--warning-color);"></i><span id="pendingCountMobile">0</span></div>
    <div class="stats-strip-item"><i class="fas fa-cog" style="color: var(--info-color);"></i><span id="processingCountMobile">0</span></div>
    <div class="stats-strip-item"><i class="fas fa-check-circle" style="color: var(--success-color);"></i><span id="completedCountMobile">0</span></div>
    <div class="stats-strip-item"><i class="fas fa-times-circle" style="color: var(--danger-color);"></i><span id="failedCountMobile">0</span></div>
</div>

<!-- Desktop Stats Cards -->
<div class="row mb-3 g-2 d-none d-md-flex">
    <div class="col-3">
        <div class="card hover-lift stats-card">
            <div class="card-body text-center">
                <div class="mb-3"><i class="fas fa-clock fa-3x" style="color: var(--warning-color);"></i></div>
                <h5 class="card-title mb-1" id="pendingCount">0</h5>
                <p class="card-text text-muted mb-0">Pending</p>
            </div>
        </div>
    </div>
    <div class="col-3">
        <div class="card hover-lift stats-card">
            <div class="card-body text-center">
                <div class="mb-3"><i class="fas fa-cog fa-spin fa-3x" style="color: var(--info-color);"></i></div>
                <h5 class="card-title mb-1" id="processingCount">0</h5>
                <p class="card-text text-muted mb-0">Processing</p>
            </div>
        </div>
    </div>
    <div class="col-3">
        <div class="card hover-lift stats-card">
            <div class="card-body text-center">
                <div class="mb-3"><i class="fas fa-check-circle fa-3x" style="color: var(--success-color);"></i></div>
                <h5 class="card-title mb-1" id="completedCount">0</h5>
                <p class="card-text text-muted mb-0">Completed</p>
            </div>
        </div>
    </div>
    <div class="col-3">
        <div class="card hover-lift stats-card">
            <div class="card-body text-center">
                <div class="mb-3"><i class="fas fa-exclamation-circle fa-3x" style="color: var(--danger-color);"></i></div>
                <h5 class="card-title mb-1" id="failedCount">0</h5>
                <p class="card-text text-muted mb-0">Failed</p>
            </div>
        </div>
    </div>
</div>


<!-- Node Mode Banner (hidden by default, shown via JS when in node mode) -->
<div class="row mb-3" id="nodeBanner" style="display: none;">
    <div class="col-12">
        <div class="alert alert-info d-flex align-items-center justify-content-between mb-0">
            <div>
                <i class="fas fa-satellite-dish me-2"></i>
                <strong>Node Mode</strong> — This instance is operating as a worker node for
                <span id="nodeBannerMaster">a master</span>.
                <span id="nodeBannerStatus" class="ms-2 text-muted">Waiting for jobs...</span>
            </div>
            <button class="btn btn-sm btn-outline-light" id="switchToStandalone">
                <i class="fas fa-unlink me-1"></i>Switch to Standalone
            </button>
        </div>
    </div>
</div>

<!-- Cluster Status Panel (hidden by default, shown when cluster enabled) -->
<div class="row mb-3" id="clusterPanel" style="display: none;">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center" style="cursor: pointer;" data-bs-toggle="collapse" data-bs-target="#clusterPanelBody">
                <h6 class="mb-0">
                    <i class="fas fa-network-wired me-2"></i>
                    Cluster
                    <span class="badge bg-secondary ms-2" id="clusterNodeCount">0 nodes</span>
                </h6>
                <i class="fas fa-chevron-down" id="clusterCollapseIcon"></i>
            </div>
            <div class="collapse show" id="clusterPanelBody">
                <div class="card-body">
                    <div class="d-flex flex-wrap gap-3" id="clusterNodesContainer">
                        <div class="text-muted"><i class="fas fa-search me-1"></i>Discovering nodes...</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Now Processing Section -->
<div class="row mb-4" id="processingSection" style="display: none;">
    <div class="col-md-12">
        <div class="card border-info">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="fas fa-cog fa-spin me-2 text-info"></i>
                    Now Processing
                </h5>
            </div>
            <div class="card-body" id="processingContainer">
            </div>
        </div>
    </div>
</div>

<!-- Work Queue Section -->
<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <div class="d-flex justify-content-between align-items-center flex-wrap">
                    <h5 class="mb-0">
                        <i class="fas fa-list-ul me-2"></i>
                        Queue
                    </h5>
                    <div id="queueFilterTabs" class="btn-group btn-group-sm mt-2 mt-md-0"></div>
                </div>
            </div>
            <div class="card-body">
                <div id="workItemsContainer" style="min-height: 100px;">
                    <div class="text-center text-muted py-5">
                        <i class="fas fa-inbox fa-4x mb-3" style="opacity: 0.3;"></i>
                        <h5>No work items yet</h5>
                        <p>Click "Browse Library" to add videos to the transcoding queue</p>
                    </div>
                </div>
                <div id="queuePagination"></div>
            </div>
        </div>
    </div>
</div>

<!-- Library Browser Modal -->
<div class="snacks-modal-backdrop" id="libraryModal">
    <div class="snacks-modal-wrapper">
        <div class="snacks-modal-dialog">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-folder-open me-2"></i>
                    Video Library Browser
                </h5>
                <button type="button" class="btn-close" onclick="document.getElementById('libraryModal').classList.remove('open')"></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-lg-4">
                        <h6><i class="fas fa-folder me-2"></i>Directories</h6>
                        <div id="directoryList" class="border rounded p-2" style="height: 450px; overflow-y: auto;">
                            <div class="text-center">
                                <div class="spinner-border" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-8">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6><i class="fas fa-file-video me-2"></i>Video Files</h6>
                            <div>
                                <button id="selectAllFiles" class="btn btn-sm btn-outline-secondary me-2">
                                    <i class="fas fa-check-square me-1"></i> Select All
                                </button>
                                <button id="processSelectedFiles" class="btn btn-sm btn-primary" disabled>
                                    <i class="fas fa-play me-1"></i> Process Selected
                                </button>
                            </div>
                        </div>
                        <div id="fileList" class="border rounded p-2" style="height: 450px; overflow-y: auto;">
                            <div class="text-muted text-center py-4">
                                <i class="fas fa-folder-open fa-2x mb-2"></i><br>
                                Select a directory to view files
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="document.getElementById('libraryModal').classList.remove('open')">Close</button>
                <button type="button" class="btn btn-primary" id="processDirectory">
                    <i class="fas fa-folder-plus me-2"></i>
                    Process Entire Directory
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Settings Modal -->
<div class="snacks-modal-backdrop" id="settingsModal">
    <div class="snacks-modal-wrapper">
        <div class="snacks-modal-dialog">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-cog me-2"></i>Settings</h5>
                <button type="button" class="btn-close" onclick="document.getElementById('settingsModal').classList.remove('open')"></button>
            </div>
            <div class="modal-body">
                <div class="settings-tabs-wrapper">
                    <button type="button" class="settings-tab-arrow settings-tab-arrow-left" aria-label="Scroll tabs left"><i class="fas fa-chevron-left"></i></button>
                    <ul class="nav nav-tabs settings-tabs" role="tablist">
                        <li class="nav-item" data-role-visible="master standalone"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#generalTab" type="button" role="tab"><i class="fas fa-sliders me-1"></i> General</button></li>
                        <li class="nav-item" data-role-visible="master standalone"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#audioTab" type="button" role="tab"><i class="fas fa-volume-high me-1"></i> Audio</button></li>
                        <li class="nav-item" data-role-visible="master standalone"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#subtitleTab" type="button" role="tab"><i class="fas fa-closed-captioning me-1"></i> Subtitles</button></li>
                        <li class="nav-item" data-role-visible="master standalone"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#muxTab" type="button" role="tab"><i class="fas fa-layer-group me-1"></i> Mux</button></li>
                        <li class="nav-item" data-role-visible="master standalone"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#videoTab" type="button" role="tab"><i class="fas fa-film me-1"></i> Video</button></li>
                        <li class="nav-item" data-role-visible="master standalone"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#libraryTab" type="button" role="tab"><i class="fas fa-folder-tree me-1"></i> Library</button></li>
                        <li class="nav-item" data-role-visible="master standalone"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#integrationsTab" type="button" role="tab"><i class="fas fa-plug me-1"></i> Integrations</button></li>
                        <li class="nav-item" data-role-visible="node"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#nodeSyncTab" type="button" role="tab"><i class="fas fa-sync me-1"></i> Integration Sync</button></li>
                        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#clusterTab" type="button" role="tab"><i class="fas fa-network-wired me-1"></i> Cluster</button></li>
                        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#securityTab" type="button" role="tab"><i class="fas fa-lock me-1"></i> Security</button></li>
                        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#advancedTab" type="button" role="tab"><i class="fas fa-screwdriver-wrench me-1"></i> Advanced</button></li>
                    </ul>
                    <button type="button" class="settings-tab-arrow settings-tab-arrow-right" aria-label="Scroll tabs right"><i class="fas fa-chevron-right"></i></button>
                </div>
                <div class="tab-content mt-3">
                    <div class="tab-pane fade show active" id="generalTab"      role="tabpanel" data-role-visible="master standalone">@await Html.PartialAsync("_GeneralSettings", null, new ViewDataDictionary(ViewData) { {"FormPrefix", "settings"} })</div>
                    <div class="tab-pane fade"             id="audioTab"        role="tabpanel" data-role-visible="master standalone">@await Html.PartialAsync("_AudioSettings", null, new ViewDataDictionary(ViewData) { {"FormPrefix", "settings"} })</div>
                    <div class="tab-pane fade"             id="subtitleTab"     role="tabpanel" data-role-visible="master standalone">@await Html.PartialAsync("_SubtitleSettings", null, new ViewDataDictionary(ViewData) { {"FormPrefix", "settings"} })</div>
                    <div class="tab-pane fade"             id="muxTab"          role="tabpanel" data-role-visible="master standalone">@await Html.PartialAsync("_MuxSettings", null, new ViewDataDictionary(ViewData) { {"FormPrefix", "settings"} })</div>
                    <div class="tab-pane fade"             id="videoTab"        role="tabpanel" data-role-visible="master standalone">@await Html.PartialAsync("_VideoSettings", null, new ViewDataDictionary(ViewData) { {"FormPrefix", "settings"} })</div>
                    <div class="tab-pane fade"             id="libraryTab"      role="tabpanel" data-role-visible="master standalone">@await Html.PartialAsync("_LibrarySettings")</div>
                    <div class="tab-pane fade"             id="integrationsTab" role="tabpanel" data-role-visible="master standalone">@await Html.PartialAsync("_IntegrationSettings")</div>
                    <div class="tab-pane fade"             id="clusterTab"      role="tabpanel">@await Html.PartialAsync("_ClusterSettings")</div>
                    <div class="tab-pane fade"             id="securityTab"     role="tabpanel">@await Html.PartialAsync("_SecuritySettings")</div>
                    <div class="tab-pane fade"             id="advancedTab"     role="tabpanel">@await Html.PartialAsync("_AdvancedSettings")</div>

                    <div class="tab-pane fade" id="nodeSyncTab" role="tabpanel" data-role-visible="node">
                        <div class="alert alert-info mb-4">
                            <i class="fas fa-info-circle me-2"></i>
                            <strong>Worker mode.</strong> Encoding settings (codec, bitrate, filters, integrations)
                            are managed by the master. This worker pulls the master's integration credentials
                            before every encode — they are never edited locally.
                        </div>
                        <div class="encoder-panel rounded">
                            <h6 class="fw-bold mb-3"><i class="fas fa-sync me-2 text-primary"></i>Integration Sync Status</h6>
                            <dl class="row mb-3">
                                <dt class="col-sm-3">Master URL</dt>
                                <dd class="col-sm-9"><code id="nodeSyncMasterUrl">—</code></dd>
                                <dt class="col-sm-3">Last sync</dt>
                                <dd class="col-sm-9"><span id="nodeSyncLastAt">Never</span></dd>
                                <dt class="col-sm-3">Status</dt>
                                <dd class="col-sm-9"><span id="nodeSyncStatus" class="badge bg-secondary">Unknown</span></dd>
                            </dl>
                            <button class="btn btn-sm btn-outline-primary" id="nodeSyncRefreshBtn"><i class="fas fa-rotate me-1"></i>Pull from master now</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="document.getElementById('settingsModal').classList.remove('open')">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Override Dialog (sits above settings modal via higher z-index) -->
<div class="snacks-modal-backdrop" id="overrideDialog" style="--snacks-modal-z: 9100">
    <div class="snacks-modal-wrapper">
        <div class="snacks-modal-dialog" style="max-width: 800px;">
            <div class="modal-header">
                <h5 id="overrideDialogTitle"></h5>
                <button type="button" class="btn-close" onclick="document.getElementById('overrideDialog').classList.remove('open')"></button>
            </div>
            <div class="modal-body">
        <div id="overrideNodeRules" style="display: none;">
            <h6 class="fw-bold mb-2"><i class="fas fa-filter me-1"></i> 4K Dispatch Rules</h6>
            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="nodeOnly4K">
                <label class="form-check-label" for="nodeOnly4K">Only dispatch 4K jobs to this node</label>
            </div>
            <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" id="nodeExclude4K">
                <label class="form-check-label" for="nodeExclude4K">Never dispatch 4K jobs to this node</label>
            </div>
            <hr>
        </div>
        <h6 class="fw-bold mb-2">
            <i class="fas fa-cogs me-1"></i> Encoding Overrides
            <small class="text-muted fw-normal ms-2">Only checked fields override the global settings</small>
        </h6>
        <div id="overrideFields">
            <div class="encoder-panel rounded mb-3">
            <h6 class="fw-bold mb-3"><i class="fas fa-cogs me-2 text-primary"></i>General</h6>
            <div class="row g-2">
                <div class="col-md-6">
                    <div class="form-check mb-2" data-context="folder,node">
                        <input class="form-check-input override-toggle" type="checkbox" id="ovr_Format" data-field="Format">
                        <label class="form-check-label" for="ovr_Format">Output Format</label>
                        <select class="form-select form-select-sm mt-1" id="ovrFormat" disabled>
                            <option value="mkv">MKV (Matroska)</option><option value="mp4">MP4</option>
                        </select>
                    </div>
                    <div class="form-check mb-2" data-context="folder,node">
                        <input class="form-check-input override-toggle" type="checkbox" id="ovr_Codec" data-field="Codec">
                        <label class="form-check-label" for="ovr_Codec">Video Codec</label>
                        <select class="form-select form-select-sm mt-1" id="ovrCodec" disabled>
                            <option value="h265">H.265/HEVC</option><option value="h264">H.264/AVC</option><option value="av1">AV1</option>
                        </select>
                    </div>
                    <div class="form-check mb-2" data-context="folder,node">
                        <input class="form-check-input override-toggle" type="checkbox" id="ovr_TargetBitrate" data-field="TargetBitrate">
                        <label class="form-check-label" for="ovr_TargetBitrate">Target Bitrate (kbps)</label>
                        <input type="number" class="form-control form-control-sm mt-1" id="ovrTargetBitrate" min="500" max="50000" step="100" value="3500" disabled>
                    </div>
                    <div class="form-check mb-2" data-context="folder,node">
                        <input class="form-check-input override-toggle" type="checkbox" id="ovr_StrictBitrate" data-field="StrictBitrate">
                        <label class="form-check-label" for="ovr_StrictBitrate">Strict Bitrate</label>
                        <div class="form-check form-switch mt-1"><input class="form-check-input" type="checkbox" id="ovrStrictBitrate" disabled></div>
                    </div>
                    <div class="form-check mb-2" data-context="folder,node">
                        <input class="form-check-input override-toggle" type="checkbox" id="ovr_FourKBitrateMultiplier" data-field="FourKBitrateMultiplier">
                        <label class="form-check-label" for="ovr_FourKBitrateMultiplier">4K Bitrate Multiplier</label>
                        <select class="form-select form-select-sm mt-1" id="ovrFourKBitrateMultiplier" disabled>
                            <option value="2">2x</option><option value="3">3x</option><option value="4">4x</option><option value="5">5x</option><option value="6">6x</option><option value="8">8x</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-check mb-2" data-context="folder">
                        <input class="form-check-input override-toggle" type="checkbox" id="ovr_Skip4K" data-field="Skip4K">
                        <label class="form-check-label" for="ovr_Skip4K">Skip 4K Videos</label>
                        <div class="form-check form-switch mt-1"><input class="form-check-input" type="checkbox" id="ovrSkip4K" disabled></div>
                    </div>
                    <div class="form-check mb-2" data-context="folder">
                        <input class="form-check-input override-toggle" type="checkbox" id="ovr_SkipPercentAboveTarget" data-field="SkipPercentAboveTarget">
                        <label class="form-check-label" for="ovr_SkipPercentAboveTarget">Skip Threshold (%)</label>
                        <input type="number" class="form-control form-control-sm mt-1" id="ovrSkipPercentAboveTarget" min="0" max="100" value="20" disabled>
                    </div>
                    <div class="form-check mb-2" data-context="folder">
                        <input class="form-check-input override-toggle" type="checkbox" id="ovr_DeleteOriginalFile" data-field="DeleteOriginalFile">
                        <label class="form-check-label" for="ovr_DeleteOriginalFile">Replace Original Files</label>
                        <div class="form-check form-switch mt-1"><input class="form-check-input" type="checkbox" id="ovrDeleteOriginalFile" disabled></div>
                    </div>
                    <div class="form-check mb-2" data-context="folder,node">
                        <input class="form-check-input override-toggle" type="checkbox" id="ovr_RetryOnFail" data-field="RetryOnFail">
                        <label class="form-check-label" for="ovr_RetryOnFail">Retry on Failure</label>
                        <div class="form-check form-switch mt-1"><input class="form-check-input" type="checkbox" id="ovrRetryOnFail" disabled></div>
                    </div>
                </div>
            </div>

            </div>

            <div class="encoder-panel rounded mb-3">
            <h6 class="fw-bold mb-3"><i class="fas fa-film me-2 text-info"></i>Video Pipeline</h6>
            <div class="row g-2">
                <div class="col-md-6">
                    <div class="form-check mb-2" data-context="folder,node">
                        <input class="form-check-input override-toggle" type="checkbox" id="ovr_DownscalePolicy" data-field="DownscalePolicy">
                        <label class="form-check-label" for="ovr_DownscalePolicy">Downscale Policy</label>
                        <select class="form-select form-select-sm mt-1" id="ovrDownscalePolicy" disabled>
                            <option value="Never">Never</option><option value="CapAtTarget">Cap at target</option><option value="Always">Always downscale</option>
                        </select>
                    </div>
                    <div class="form-check mb-2" data-context="folder,node">
                        <input class="form-check-input override-toggle" type="checkbox" id="ovr_DownscaleTarget" data-field="DownscaleTarget">
                        <label class="form-check-label" for="ovr_DownscaleTarget">Downscale Target</label>
                        <select class="form-select form-select-sm mt-1" id="ovrDownscaleTarget" disabled>
                            <option value="4K">4K (2160p)</option><option value="1440p">1440p</option><option value="1080p">1080p</option><option value="720p">720p</option>
                        </select>
                    </div>
                    <div class="form-check mb-2" data-context="folder,node">
                        <input class="form-check-input override-toggle" type="checkbox" id="ovr_FfmpegQualityPreset" data-field="FfmpegQualityPreset">
                        <label class="form-check-label" for="ovr_FfmpegQualityPreset">FFmpeg Preset</label>
                        <select class="form-select form-select-sm mt-1" id="ovrFfmpegQualityPreset" disabled>
                            <option value="veryfast">veryfast</option><option value="fast">fast</option><option value="medium">medium</option><option value="slow">slow</option><option value="veryslow">veryslow</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-check mb-2" data-context="folder,node">
                        <input class="form-check-input override-toggle" type="checkbox" id="ovr_TonemapHdrToSdr" data-field="TonemapHdrToSdr">
                        <label class="form-check-label" for="ovr_TonemapHdrToSdr">Tonemap HDR → SDR</label>
                        <div class="form-check form-switch mt-1"><input class="form-check-input" type="checkbox" id="ovrTonemapHdrToSdr" disabled></div>
                    </div>
                    <div class="form-check mb-2" data-context="folder,node">
                        <input class="form-check-input override-toggle" type="checkbox" id="ovr_RemoveBlackBorders" data-field="RemoveBlackBorders">
                        <label class="form-check-label" for="ovr_RemoveBlackBorders">Remove Black Borders</label>
                        <div class="form-check form-switch mt-1"><input class="form-check-input" type="checkbox" id="ovrRemoveBlackBorders" disabled></div>
                    </div>
                </div>
            </div>

            </div>

            <div class="encoder-panel rounded mb-3">
            <h6 class="fw-bold mb-3"><i class="fas fa-volume-high me-2 text-primary"></i>Audio</h6>
            <div class="row g-2">
                <div class="col-md-6">
                    <div class="form-check mb-2" data-context="folder,node">
                        <input class="form-check-input override-toggle" type="checkbox" id="ovr_AudioCodec" data-field="AudioCodec">
                        <label class="form-check-label" for="ovr_AudioCodec">Audio Codec</label>
                        <select class="form-select form-select-sm mt-1" id="ovrAudioCodec" disabled>
                            <option value="copy">Copy (no re-encode)</option><option value="aac">AAC</option><option value="eac3">E-AC3</option><option value="opus">Opus</option>
                        </select>
                    </div>
                    <div class="form-check mb-2" data-context="folder,node">
                        <input class="form-check-input override-toggle" type="checkbox" id="ovr_AudioBitrateKbps" data-field="AudioBitrateKbps">
                        <label class="form-check-label" for="ovr_AudioBitrateKbps">Audio Bitrate (kbps)</label>
                        <input type="number" class="form-control form-control-sm mt-1" id="ovrAudioBitrateKbps" min="32" max="1536" step="16" value="192" disabled>
                    </div>
                    <div class="form-check mb-2" data-context="folder,node">
                        <input class="form-check-input override-toggle" type="checkbox" id="ovr_TwoChannelAudio" data-field="TwoChannelAudio">
                        <label class="form-check-label" for="ovr_TwoChannelAudio">Downmix to Stereo</label>
                        <div class="form-check form-switch mt-1"><input class="form-check-input" type="checkbox" id="ovrTwoChannelAudio" disabled></div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-check mb-2" data-context="folder,node">
                        <input class="form-check-input override-toggle" type="checkbox" id="ovr_KeepOriginalLanguage" data-field="KeepOriginalLanguage">
                        <label class="form-check-label" for="ovr_KeepOriginalLanguage">Auto-keep Original Language</label>
                        <div class="form-check form-switch mt-1"><input class="form-check-input" type="checkbox" id="ovrKeepOriginalLanguage" disabled></div>
                    </div>
                    <div class="form-check mb-2" data-context="folder,node">
                        <input class="form-check-input override-toggle" type="checkbox" id="ovr_OriginalLanguageProvider" data-field="OriginalLanguageProvider">
                        <label class="form-check-label" for="ovr_OriginalLanguageProvider">Original-Language Provider</label>
                        <select class="form-select form-select-sm mt-1" id="ovrOriginalLanguageProvider" disabled>
                            <option value="None">None</option><option value="Auto">Auto (pick best available)</option>
                            <option value="Sonarr">Sonarr (TV)</option><option value="Radarr">Radarr (Movies)</option>
                            <option value="TVDB">TVDB (TV)</option><option value="TMDb">TMDb</option>
                        </select>
                    </div>
                </div>
            </div>

            </div>

            <div class="encoder-panel rounded mb-3">
            <h6 class="fw-bold mb-3"><i class="fas fa-closed-captioning me-2 text-info"></i>Subtitles</h6>
            <div class="row g-2">
                <div class="col-md-6">
                    <div class="form-check mb-2" data-context="folder,node">
                        <input class="form-check-input override-toggle" type="checkbox" id="ovr_ExtractSubtitlesToSidecar" data-field="ExtractSubtitlesToSidecar">
                        <label class="form-check-label" for="ovr_ExtractSubtitlesToSidecar">Extract Subtitles to Sidecar Files</label>
                        <div class="form-check form-switch mt-1"><input class="form-check-input" type="checkbox" id="ovrExtractSubtitlesToSidecar" disabled></div>
                    </div>
                    <div class="form-check mb-2" data-context="folder,node">
                        <input class="form-check-input override-toggle" type="checkbox" id="ovr_SidecarSubtitleFormat" data-field="SidecarSubtitleFormat">
                        <label class="form-check-label" for="ovr_SidecarSubtitleFormat">Sidecar Subtitle Format</label>
                        <select class="form-select form-select-sm mt-1" id="ovrSidecarSubtitleFormat" disabled>
                            <option value="srt">SRT (text)</option><option value="ass">ASS (styled text)</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-check mb-2" data-context="folder,node">
                        <input class="form-check-input override-toggle" type="checkbox" id="ovr_ConvertImageSubtitlesToSrt" data-field="ConvertImageSubtitlesToSrt">
                        <label class="form-check-label" for="ovr_ConvertImageSubtitlesToSrt">OCR Image Subtitles to SRT</label>
                        <div class="form-check form-switch mt-1"><input class="form-check-input" type="checkbox" id="ovrConvertImageSubtitlesToSrt" disabled></div>
                    </div>
                </div>
            </div>
            </div>

            <div class="encoder-panel rounded mb-3">
            <h6 class="fw-bold mb-3"><i class="fas fa-layer-group me-2 text-primary"></i>Mux</h6>
            <div class="row g-2">
                <div class="col-md-6">
                    <div class="form-check mb-2" data-context="folder,node">
                        <input class="form-check-input override-toggle" type="checkbox" id="ovr_MuxMode" data-field="MuxMode">
                        <label class="form-check-label" for="ovr_MuxMode">Mux Mode</label>
                        <select class="form-select form-select-sm mt-1" id="ovrMuxMode" disabled>
                            <option value="Off">Off</option>
                            <option value="Audio">Audio only</option>
                            <option value="Subtitles">Subtitles only</option>
                            <option value="Both">Audio + Subtitles</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-check mb-2" data-context="folder,node">
                        <input class="form-check-input override-toggle" type="checkbox" id="ovr_MuxScope" data-field="MuxScope">
                        <label class="form-check-label" for="ovr_MuxScope">Mux Apply To</label>
                        <select class="form-select form-select-sm mt-1" id="ovrMuxScope" disabled>
                            <option value="TargetMatchOnly">Files meeting bitrate targets</option>
                            <option value="AllFiles">All files</option>
                        </select>
                    </div>
                </div>
            </div>
            </div>
        </div>
    </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="document.getElementById('overrideDialog').classList.remove('open')">Cancel</button>
                <button type="button" class="btn btn-danger" id="overrideDialogReset">Reset to Defaults</button>
                <button type="button" class="btn btn-primary" id="overrideDialogSave"><i class="fas fa-save me-1"></i>Save</button>
            </div>
        </div>
    </div>
</div>

<!-- Folder Picker Modal (folders only — attached to directory inputs via .folder-picker-btn) -->
<div class="snacks-modal-backdrop" id="folderPickerModal" style="--snacks-modal-z: 9200">
    <div class="snacks-modal-wrapper">
        <div class="snacks-modal-dialog" style="max-width: 640px;">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-folder-tree me-2"></i>Select Folder</h5>
                <button type="button" class="btn-close" onclick="document.getElementById('folderPickerModal').classList.remove('open')"></button>
            </div>
            <div class="modal-body">
                <div class="folder-picker-breadcrumb mb-2 small text-muted" id="folderPickerBreadcrumb">/</div>
                <div class="input-group input-group-sm mb-2">
                    <span class="input-group-text"><i class="fas fa-keyboard"></i></span>
                    <input type="text" class="form-control" id="folderPickerManualPath" placeholder="Or type a path directly and press Enter">
                </div>
                <div id="folderPickerList" class="border rounded p-2" style="height: 360px; overflow-y: auto;">
                    <div class="text-center text-muted py-4">
                        <div class="spinner-border spinner-border-sm" role="status"></div>
                        <div class="mt-2 small">Loading folders…</div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <div class="me-auto small text-muted" id="folderPickerSelection">No folder selected</div>
                <button type="button" class="btn btn-secondary" onclick="document.getElementById('folderPickerModal').classList.remove('open')">Cancel</button>
                <button type="button" class="btn btn-primary" id="folderPickerConfirm" disabled><i class="fas fa-check me-1"></i> Select</button>
            </div>
        </div>
    </div>
</div>

<!-- Stop/Cancel Modal -->
<div class="snacks-modal-backdrop" id="stopCancelModal" style="--snacks-modal-z: 9050">
    <div class="snacks-modal-wrapper">
        <div class="snacks-modal-dialog" style="max-width: 520px;">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-question-circle me-2"></i>Remove from Queue</h5>
                <button type="button" class="btn-close" data-snacks-dismiss="stopCancelModal"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0">What would you like to do with this item?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-warning" id="stopCancelStop"><i class="fas fa-pause me-1"></i>Stop (Encode Later)</button>
                <button type="button" class="btn btn-danger"  id="stopCancelCancel"><i class="fas fa-ban me-1"></i>Cancel (Don't Reprocess)</button>
            </div>
        </div>
    </div>
</div>

<!-- Log Modal -->
<div class="snacks-modal-backdrop" id="logModal" style="--snacks-modal-z: 9050">
    <div class="snacks-modal-wrapper">
        <div class="snacks-modal-dialog" style="max-width: 1140px;">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-terminal me-2"></i>Transcoding Log</h5>
                <button type="button" class="btn-close" data-snacks-dismiss="logModal"></button>
            </div>
            <div class="modal-body">
                <div id="logContent"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-snacks-dismiss="logModal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Confirm Modal -->
<div class="snacks-modal-backdrop" id="confirmModal" style="--snacks-modal-z: 9300">
    <div class="snacks-modal-wrapper">
        <div class="snacks-modal-dialog" style="max-width: 520px;">
            <div class="modal-header">
                <h5 class="modal-title" id="confirmModalTitle"><i class="fas fa-exclamation-triangle me-2"></i>Confirm</h5>
                <button type="button" class="btn-close" data-snacks-dismiss="confirmModal"></button>
            </div>
            <div class="modal-body" id="confirmModalBody"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-snacks-dismiss="confirmModal">Cancel</button>
                <button type="button" class="btn btn-danger"    id="confirmModalConfirm">Confirm</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script type="module" src="~/js/main.js"></script>
}