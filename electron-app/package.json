{
  "name": "snacks",
  "version": "2.8.1",
  "description": "Snacks - Automated video transcoding",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac --arm64"
  },
  "dependencies": {
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1"
  },
  "author": "Derek Morris",
  "build": {
    "appId": "com.snacks.transcoder",
    "productName": "Snacks",
    "publish": null,
    "win": {
      "target": "nsis",
      "icon": "icons/snacks.ico",
      "signtoolOptions": {
        "publisherName": "Derek Morris"
      }
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": "arm64" }
      ],
      "icon": "icons/snacks.icns",
      "category": "public.app-category.video",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "extendInfo": {
        "LSMinimumSystemVersion": "11.0"
      }
    },
    "dmg": {
      "title": "Snacks ${version}",
      "icon": "icons/snacks.icns"
    },
    "afterSign": "scripts/notarize.js",
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Snacks",
      "installerIcon": "icons/snacks.ico",
      "uninstallerIcon": "icons/snacks.ico",
      "installerHeaderIcon": "icons/snacks.ico",
      "include": "installer.nsh"
    },
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "ffmpeg",
        "to": "ffmpeg",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "main.js",
      "icons/**/*",
      "scripts/**/*"
    ]
  }
}
